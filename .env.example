CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_SERCRET_KEY=
CF_S3_ENDPOINT=

# Optional Worker names (defaults shown).
CF_FRONT_WORKER_NAME=alleycat
CF_CMS_WORKER_NAME=alleycat-cms

