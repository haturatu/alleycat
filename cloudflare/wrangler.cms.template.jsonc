{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "alleycat-cms",
  "main": "src/cms.ts",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "./cms-public",
    "binding": "ASSETS",
    "run_worker_first": ["/*"]
  }
}
